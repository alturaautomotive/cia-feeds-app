DATABASE_URL=postgresql://user:password@localhost:5432/ciafeeds
NEXTAUTH_SECRET=your-random-secret-string-here
# REQUIRED: Must exactly match the public URL of the deployed app (e.g. https://yourapp.vercel.app).
# If set to localhost in production, session cookies will fail and getServerSession will return null.
# Also ensure NEXTAUTH_SECRET is identical across all environments (local, preview, production).
NEXTAUTH_URL=http://localhost:3000
# REQUIRED: Public app URL used to build OAuth callback URIs (/api/fb/callback, /api/meta/callback).
# Must match a valid redirect URI registered in the Meta App → Facebook Login → Settings.
# In production, set to the canonical HTTPS domain (e.g. https://yourapp.vercel.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key-here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PRICE_ID=price_your_stripe_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
DIRECT_URL=postgresql://user:password@localhost:5432/ciafeeds
RESEND_API_KEY=re_your_resend_api_key
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=sk-your-openai-api-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Required — Google Maps Geocoding API key used to geocode dealer addresses in /api/profile
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Optional — internal email for new signup alerts
ADMIN_EMAIL=admin@example.com
SYNC_SECRET=your-sync-secret
CRON_SECRET=your-cron-secret-here
# Required — 64-char hex string (32 bytes) used to AES-256-GCM encrypt Meta access tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key-here

# ── Meta / Facebook App Credentials ──────────────────────────────────────────
# At least ONE complete pair is required for OAuth and token exchange.
#
# Precedence: FB_APP_ID + FB_APP_SECRET are preferred (used when both are set).
# Fallback:   META_APP_ID + META_APP_SECRET are used only if the FB_* pair is absent.
# Mixed config (e.g. FB_APP_ID + META_APP_SECRET) is NOT supported and will fail.
#
# These credentials come from your Meta App → Settings → Basic in the Meta
# developer dashboard. Both OAuth flows (/api/fb/* and /api/meta/*) share the
# same underlying app; the keys are simply aliased for naming flexibility.
FB_APP_ID=your-facebook-app-id
FB_APP_SECRET=your-facebook-app-secret
# META_APP_ID=your-meta-app-id
# META_APP_SECRET=your-meta-app-secret
