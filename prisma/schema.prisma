// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Dealer {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  passwordHash         String
  slug                 String    @unique
  vertical             String    @default("automotive")
  active               Boolean   @default(true)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?
  createdAt            DateTime  @default(now())
  profileImageUrl      String?
  websiteUrl           String?
  autoCrawlEnabled     Boolean   @default(false)
  vehicles             Vehicle[]
  listings             Listing[]
  crawlJobs            CrawlJob[]
  crawlSnapshots       CrawlSnapshot[]
}

model Vehicle {
  id             String   @id @default(uuid())
  dealerId       String
  dealer         Dealer   @relation(fields: [dealerId], references: [id])
  description    String?
  vin            String?
  make           String?
  model          String?
  year           String?
  bodyStyle      String?
  price          Float?
  mileageValue   Float?
  stateOfVehicle String?
  exteriorColor  String?
  url            String
  imageUrl       String?
  images         String[] @default([])
  spotlightImageUrl String?
  isComplete     Boolean  @default(false)
  missingFields  String[]
  scrapeStatus   String   @default("pending")
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([dealerId, url])
  @@index([dealerId])
  @@index([dealerId, archivedAt])
}

model Listing {
  id            String    @id @default(uuid())
  dealerId      String
  dealer        Dealer    @relation(fields: [dealerId], references: [id])
  vertical      String
  title         String
  price         Float?
  imageUrls     String[]  @default([])
  url           String?
  isComplete    Boolean   @default(false)
  missingFields String[]
  archivedAt    DateTime?
  data          Json
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([dealerId, vertical])
  @@index([dealerId, archivedAt])
}

model CrawlJob {
  id          String         @id @default(uuid())
  dealerId    String
  dealer      Dealer         @relation(fields: [dealerId], references: [id])
  status      String         @default("pending") // pending | running | complete | failed
  startedAt   DateTime       @default(now())
  completedAt DateTime?
  urlsFound   Int            @default(0)
  snapshots   CrawlSnapshot[]

  @@index([dealerId])
}

model CrawlSnapshot {
  id          String   @id @default(uuid())
  crawlJobId  String
  crawlJob    CrawlJob @relation(fields: [crawlJobId], references: [id])
  dealerId    String
  dealer      Dealer   @relation(fields: [dealerId], references: [id])
  url         String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  weeksActive Int      @default(1)
  addedToFeed Boolean  @default(false)
  make          String?
  model         String?
  year          Int?
  price         Float?
  title         String?
  thumbnailUrl  String?

  @@unique([dealerId, url])
  @@index([dealerId])
  @@index([crawlJobId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
