// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CtaPreference {
  sms
  whatsapp
  messenger
}

enum Vertical {
  automotive
  services
  ecommerce
  realestate
}

model Dealer {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  passwordHash         String
  slug                 String    @unique
  vertical             Vertical  @default(automotive)
  active               Boolean   @default(true)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?
  createdAt            DateTime  @default(now())
  profileImageUrl      String?
  websiteUrl           String?
  autoCrawlEnabled     Boolean   @default(false)
  urlHealthCheckEnabled Boolean  @default(true)
  fbPageId             String?
  metaAccessToken      String?
  metaBusinessId       String?
  metaCatalogId        String?
  metaFeedId           String?
  metaPixelId          String?
  metaTokenType        String?
  metaTokenExpiresAt   DateTime?
  metaCatalogOwnership String?
  metaAdAccountId      String?
  metaConnectedAt      DateTime?
  metaDeliveryMethod   String    @default("csv")
  address              String?
  phone                String?
  customDomain         String?
  ctaPreference        CtaPreference?
  translationLang      String?        @default("en")
  translationTone      String?        @default("professional")
  latitude             Float?
  longitude            Float?
  feedUrlMode          String    @default("original")
  defaultSubAccountId  String?   @unique
  vehicles             Vehicle[]
  listings             Listing[]
  crawlJobs            CrawlJob[]
  crawlSnapshots       CrawlSnapshot[]
  leads                Lead[]
  subAccounts          SubAccount[]   @relation("DealerSubAccounts")
  teamUsers            TeamUser[]
  metaCatalogSyncItems MetaCatalogSyncItem[]
}

model SubAccount {
  id             String          @id @default(uuid())
  dealerId       String
  dealer         Dealer          @relation("DealerSubAccounts", fields: [dealerId], references: [id])
  vertical       Vertical        @default(automotive)
  name           String
  stripeSubId    String?
  createdAt      DateTime        @default(now())
  vehicles       Vehicle[]
  listings       Listing[]
  crawlJobs      CrawlJob[]
  crawlSnapshots CrawlSnapshot[]
  teamUsers      TeamUser[]

  @@index([dealerId])
}

model Vehicle {
  id             String      @id @default(uuid())
  dealerId       String
  dealer         Dealer      @relation(fields: [dealerId], references: [id])
  subAccountId   String?
  subAccount     SubAccount? @relation(fields: [subAccountId], references: [id])
  description    String?
  vin            String?
  make           String?
  model          String?
  year           String?
  bodyStyle      String?
  price          Float?
  mileageValue   Float?
  stateOfVehicle String?
  exteriorColor  String?
  trim           String?
  drivetrain     String?
  transmission   String?
  fuelType       String?
  msrp           Float?
  url            String
  address        String?
  latitude       Float?
  longitude      Float?
  imageUrl       String?
  images         String[] @default([])
  spotlightImageUrl String?
  isComplete     Boolean  @default(false)
  missingFields  String[]
  scrapeStatus   String   @default("pending")
  urlStatus      String   @default("active")
  urlLastCheckedAt DateTime?
  urlCheckFailed Boolean  @default(false)
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([dealerId, url])
  @@index([dealerId])
  @@index([dealerId, archivedAt])
  @@index([subAccountId])
  leads          Lead[]
}

model Lead {
  id        String   @id @default(uuid())
  dealerId  String
  vehicleId String
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  dealer    Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([dealerId])
  @@index([vehicleId])
}

model Listing {
  id                  String      @id @default(uuid())
  dealerId            String
  dealer              Dealer      @relation(fields: [dealerId], references: [id])
  subAccountId        String?
  subAccount          SubAccount? @relation(fields: [subAccountId], references: [id])
  vertical            String
  title               String
  price               Float?
  imageUrls           String[]  @default([])
  url                 String?
  // Allowed values: "draft", "validated", "ready_to_publish", "published", "blocked"
  // Enforced at the DB layer via a CHECK constraint (see migration 20260416_expand_listing_publish_statuses).
  publishStatus       String    @default("draft")
  urlValidationScore  Float?
  canonicalUrl        String?
  isComplete          Boolean   @default(false)
  missingFields       String[]
  archivedAt          DateTime?
  data                Json
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([dealerId, vertical])
  @@index([dealerId, archivedAt])
  @@index([subAccountId])
  @@unique([dealerId, canonicalUrl])
}

model CrawlJob {
  id           String         @id @default(uuid())
  dealerId     String
  dealer       Dealer         @relation(fields: [dealerId], references: [id])
  subAccountId String?
  subAccount   SubAccount?    @relation(fields: [subAccountId], references: [id])
  status       String         @default("pending") // pending | running | mapping_complete | complete | failed
  phase        String         @default("mapping") // mapping | enriching | complete
  startedAt    DateTime       @default(now())
  completedAt  DateTime?
  urlsFound    Int            @default(0)
  urlsEnriched Int            @default(0)
  snapshots    CrawlSnapshot[]

  @@index([dealerId])
  @@index([subAccountId])
}

model CrawlSnapshot {
  id           String      @id @default(uuid())
  crawlJobId   String
  crawlJob     CrawlJob    @relation(fields: [crawlJobId], references: [id])
  dealerId     String
  dealer       Dealer      @relation(fields: [dealerId], references: [id])
  subAccountId String?
  subAccount   SubAccount? @relation(fields: [subAccountId], references: [id])
  url         String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  weeksActive Int      @default(1)
  addedToFeed Boolean  @default(false)
  make          String?
  model         String?
  year          Int?
  price         Float?
  title         String?
  thumbnailUrl  String?

  @@unique([dealerId, url])
  @@index([dealerId])
  @@index([crawlJobId])
  @@index([subAccountId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model OAuthState {
  id        String   @id @default(uuid())
  state     String   @unique
  dealerId  String
  expiresAt DateTime

  @@index([state])
  @@index([expiresAt])
}

model TeamUser {
  id           String      @id @default(uuid())
  email        String
  dealerId     String
  subAccountId String?
  role         String      // "admin" | "editor"
  invitedAt    DateTime    @default(now())
  acceptedAt   DateTime?
  dealer       Dealer      @relation(fields: [dealerId], references: [id])
  subAccount   SubAccount? @relation(fields: [subAccountId], references: [id])

  @@unique([dealerId, email])
  @@index([dealerId])
  @@index([subAccountId])
}

model MetaCatalogSyncItem {
  id             String    @id @default(uuid())
  dealerId       String
  dealer         Dealer    @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  metaCatalogId  String
  entityType     String    // "automotive" | "services"
  catalogItemId  String    // The exact ID value sent to Meta (vehicle_id or listing id)
  lastSeenAt     DateTime  @default(now())
  lastDeletedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([dealerId, metaCatalogId, catalogItemId])
  @@index([dealerId, metaCatalogId, lastDeletedAt])
  @@index([dealerId])
}

model TeamInvite {
  id           String   @id @default(uuid())
  token        String   @unique
  email        String
  dealerId     String
  subAccountId String?
  role         String   // "admin" | "editor"
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
}
