// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CtaPreference {
  sms
  whatsapp
  messenger
}

enum Vertical {
  automotive
  services
  ecommerce
  realestate
}

model Dealer {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  passwordHash         String
  slug                 String    @unique
  vertical             Vertical  @default(automotive)
  active               Boolean   @default(true)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?
  createdAt            DateTime  @default(now())
  profileImageUrl      String?
  websiteUrl           String?
  autoCrawlEnabled     Boolean   @default(false)
  urlHealthCheckEnabled Boolean  @default(true)
  fbPageId             String?
  metaAccessToken      String?
  metaBusinessId       String?
  metaCatalogId        String?
  metaFeedId           String?
  metaPixelId          String?
  metaTokenType        String?
  metaTokenExpiresAt   DateTime?
  metaCatalogOwnership String?
  metaAdAccountId      String?
  metaConnectedAt      DateTime?
  metaDeliveryMethod   String    @default("csv")
  address              String?
  phone                String?
  customDomain         String?
  ctaPreference        CtaPreference?
  translationLang      String?        @default("en")
  translationTone      String?        @default("professional")
  latitude             Float?
  longitude            Float?
  feedUrlMode          String    @default("original")
  defaultSubAccountId  String?   @unique
  // Enterprise features (SECURITY_AUDIT.md)
  trackingSecret         String?    // F-2.6: HMAC key for /api/track signature
  metaTokenInvalidAt     DateTime?  // F-2.7: marker for refresh-failed; user must reconnect
  trialEndingNotifiedAt  DateTime?  // F-4.2: dedupe trial-ending email
  deletedAt              DateTime?  // F-8.3: GDPR soft-delete; 30-day grace before hard delete
  // Storefront / white-label (whitelabel)
  themePreset            String?    // key into lib/brandPresets.ts
  themeOverrides         Json?      // CSS-var overrides for "custom" preset
  logoUrl                String?    // storefront-quality logo (profileImageUrl as fallback)
  vehicles             Vehicle[]
  listings             Listing[]
  crawlJobs            CrawlJob[]
  crawlSnapshots       CrawlSnapshot[]
  leads                Lead[]
  subAccounts          SubAccount[]   @relation("DealerSubAccounts")
  teamUsers            TeamUser[]
  metaCatalogSyncItems MetaCatalogSyncItem[]
  metaDeliveryJobs     MetaDeliveryJob[]
  smsConversations     SmsConversation[]
  metaCustomAudiences  MetaCustomAudience[]
}

model SubAccount {
  id             String          @id @default(uuid())
  dealerId       String
  dealer         Dealer          @relation("DealerSubAccounts", fields: [dealerId], references: [id])
  vertical       Vertical        @default(automotive)
  name           String
  stripeSubId    String?
  createdAt      DateTime        @default(now())
  vehicles       Vehicle[]
  listings       Listing[]
  crawlJobs      CrawlJob[]
  crawlSnapshots CrawlSnapshot[]
  teamUsers      TeamUser[]

  @@index([dealerId])
}

model Vehicle {
  id             String      @id @default(uuid())
  dealerId       String
  dealer         Dealer      @relation(fields: [dealerId], references: [id])
  subAccountId   String?
  subAccount     SubAccount? @relation(fields: [subAccountId], references: [id])
  description    String?
  vin            String?
  make           String?
  model          String?
  year           String?
  bodyStyle      String?
  price          Float?
  mileageValue   Float?
  stateOfVehicle String?
  exteriorColor  String?
  trim           String?
  drivetrain     String?
  transmission   String?
  fuelType       String?
  msrp           Float?
  url            String
  address        String?
  latitude       Float?
  longitude      Float?
  imageUrl       String?
  images         String[] @default([])
  spotlightImageUrl String?
  isComplete     Boolean  @default(false)
  missingFields  String[]
  scrapeStatus   String   @default("pending")
  urlStatus      String   @default("active")
  urlLastCheckedAt DateTime?
  urlCheckFailed Boolean  @default(false)
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([dealerId, url])
  @@index([dealerId])
  @@index([dealerId, archivedAt])
  @@index([subAccountId])
  leads          Lead[]
}

model Lead {
  id        String   @id @default(uuid())
  dealerId  String
  vehicleId String?
  listingId String?
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  dealer    Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([dealerId])
  @@index([vehicleId])
  @@index([listingId])
}

model Listing {
  id                  String      @id @default(uuid())
  dealerId            String
  dealer              Dealer      @relation(fields: [dealerId], references: [id])
  subAccountId        String?
  subAccount          SubAccount? @relation(fields: [subAccountId], references: [id])
  vertical            String
  title               String
  price               Float?
  imageUrls           String[]  @default([])
  url                 String?
  // Allowed values: "draft", "validated", "ready_to_publish", "published", "blocked"
  // Enforced at the DB layer via a CHECK constraint (see migration 20260416_expand_listing_publish_statuses).
  publishStatus       String    @default("draft")
  urlValidationScore  Float?
  canonicalUrl        String?
  isComplete          Boolean   @default(false)
  missingFields       String[]
  archivedAt          DateTime?
  data                Json
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  leads               Lead[]

  @@index([dealerId, vertical])
  @@index([dealerId, archivedAt])
  @@index([subAccountId])
  @@unique([dealerId, canonicalUrl])
}

model CrawlJob {
  id           String         @id @default(uuid())
  dealerId     String
  dealer       Dealer         @relation(fields: [dealerId], references: [id])
  subAccountId String?
  subAccount   SubAccount?    @relation(fields: [subAccountId], references: [id])
  status       String         @default("pending") // pending | running | mapping_complete | complete | failed
  phase        String         @default("mapping") // mapping | enriching | complete
  startedAt    DateTime       @default(now())
  completedAt  DateTime?
  urlsFound    Int            @default(0)
  urlsEnriched Int            @default(0)
  snapshots    CrawlSnapshot[]

  @@index([dealerId])
  @@index([subAccountId])
}

model CrawlSnapshot {
  id           String      @id @default(uuid())
  crawlJobId   String
  crawlJob     CrawlJob    @relation(fields: [crawlJobId], references: [id])
  dealerId     String
  dealer       Dealer      @relation(fields: [dealerId], references: [id])
  subAccountId String?
  subAccount   SubAccount? @relation(fields: [subAccountId], references: [id])
  url         String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  weeksActive Int      @default(1)
  addedToFeed Boolean  @default(false)
  make          String?
  model         String?
  year          Int?
  price         Float?
  title         String?
  thumbnailUrl  String?

  @@unique([dealerId, url])
  @@index([dealerId])
  @@index([crawlJobId])
  @@index([subAccountId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model OAuthState {
  id        String   @id @default(uuid())
  state     String   @unique
  dealerId  String
  expiresAt DateTime

  @@index([state])
  @@index([expiresAt])
}

model TeamUser {
  id           String      @id @default(uuid())
  email        String
  name         String?
  passwordHash String?
  dealerId     String
  subAccountId String?
  role         String      // "admin" | "editor"
  invitedAt    DateTime    @default(now())
  acceptedAt   DateTime?
  dealer       Dealer      @relation(fields: [dealerId], references: [id])
  subAccount   SubAccount? @relation(fields: [subAccountId], references: [id])

  @@unique([dealerId, email])
  @@index([dealerId])
  @@index([subAccountId])
  @@index([email])
}

model MetaCatalogSyncItem {
  id             String    @id @default(uuid())
  dealerId       String
  dealer         Dealer    @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  metaCatalogId  String
  entityType     String    // "automotive" | "services"
  catalogItemId  String    // The exact ID value sent to Meta (vehicle_id or listing id)
  lastSeenAt     DateTime  @default(now())
  lastDeletedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([dealerId, metaCatalogId, catalogItemId])
  @@index([dealerId, metaCatalogId, lastDeletedAt])
  @@index([dealerId])
}

model MetaDeliveryJob {
  id                       String    @id @default(uuid())
  dealerId                 String
  dealer                   Dealer    @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  // Lifecycle
  status                   String    @default("queued") // queued | processing | retry | success | failed | blocked | skipped

  // Dedupe
  trigger                  String    @default("manual")
  coalescedCount           Int       @default(0)

  // Retry
  attemptCount             Int       @default(0)
  maxAttempts              Int       @default(5)
  nextRunAt                DateTime  @default(now())

  // Lease (prevents overlapping workers)
  leaseToken               String?
  leaseExpiresAt           DateTime?

  // Circuit breaker
  consecutiveAuthFailures  Int       @default(0)
  blockedAt                DateTime?
  blockedReason            String?

  // Last-run health snapshot
  lastRunAt                DateTime?
  lastRunStatus            String?   // success | error | skipped
  lastErrorCode            String?
  lastErrorMessage         String?
  lastItemsAttempted       Int?
  lastItemsSucceeded       Int?
  lastItemsFailed          Int?
  lastDeleteAttempted      Int?
  lastDeleteSucceeded      Int?
  lastDeleteFailed         Int?

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([status, nextRunAt])
  @@index([dealerId, status])
  // Partial unique index enforced via raw SQL migration:
  // CREATE UNIQUE INDEX ... ON "MetaDeliveryJob" ("dealerId") WHERE "status" IN ('queued','processing','retry')
}

model TeamInvite {
  id           String   @id @default(uuid())
  token        String   @unique
  email        String
  dealerId     String
  subAccountId String?
  role         String   // "admin" | "editor"
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
}

model AdminAllowlist {
  id        String   @id @default(uuid())
  email     String   @unique
  role      String   @default("admin") // "super_admin" | "admin" | "viewer"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminAuditLog {
  id             String   @id @default(uuid())
  action         String
  actorEmail     String
  actorRole      String
  actorDealerId  String?
  targetDealerId String?
  beforeState    Json?
  afterState     Json?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([action, createdAt])
  @@index([targetDealerId, createdAt])
  @@index([actorEmail, createdAt])
}

model StripeWebhookEvent {
  id          String   @id // Stripe event id
  type        String
  processedAt DateTime @default(now())
}

model RateLimitBucket {
  id          String   @id @default(uuid())
  key         String
  windowStart DateTime
  windowMs    Int
  count       Int      @default(1)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, windowStart])
  @@index([expiresAt])
}

// SMS conversation state for the Twilio-backed inbound SMS agent.
//
// Inbound-first model: a row is created the first time we receive an SMS
// from a number we recognize as a dealer (or that resolves to one via
// verification). We do not pre-create rows for every dealer because most
// dealers will never text us.
//
// The `state` field tracks multi-turn flows:
//   - idle: no pending interaction; next message is interpreted fresh
//   - awaiting_url: we asked for a URL; next message should be a URL
//   - awaiting_vertical_confirm: we asked the dealer to confirm vertical
//   - paused: dealer sent STOP and we must not send anything until START
//
// `pendingPayload` is whatever data the multi-turn flow needs to remember
// across messages (e.g. an extracted URL waiting for vertical confirmation).
//
// `optedOutAt` is set when STOP/UNSUBSCRIBE/CANCEL/END/QUIT is received.
// While set, we MUST NOT send outbound messages even if the dealer texts
// again, until they send START/UNSTOP/YES (TCPA-mandated behavior).
model SmsConversation {
  id              String    @id @default(uuid())
  dealerId        String?
  phoneNumber     String    @unique
  state           String    @default("idle")
  pendingPayload  Json?
  lastInboundAt   DateTime?
  lastOutboundAt  DateTime?
  optedOutAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  dealer   Dealer?       @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  messages SmsMessage[]

  @@index([dealerId])
}

// Audit trail for every SMS sent or received. Powers debugging, support,
// and gives us evidence of consent records (when did this number first
// text us, when did they STOP, etc.).
model SmsMessage {
  id                 String   @id @default(uuid())
  conversationId     String
  direction          String   // "inbound" | "outbound"
  body               String
  twilioMessageSid   String?  @unique
  status             String   // "received" | "queued" | "sent" | "failed"
  errorMessage       String?
  createdAt          DateTime @default(now())

  conversation SmsConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// Meta Custom Audience tracking. We store one row per dealer-audience tuple,
// keyed by an internal "audienceKind" so we can re-find it for refresh runs.
//
// audienceKind values (extend as we add more audience builders):
//   "viewed_any_30d"        - any visitor who viewed any listing in 30d
//   "viewed_listing_30d"    - one row PER listing (visitors who viewed THIS listing)
//   "lead_no_followup_30d"  - leads submitted in 30d with no follow-up
//   "lookalike_of_<key>"    - a Lookalike Audience seeded from another row
//
// metaAudienceId is the ID Meta assigns when we create the audience.
// We re-PUT to that ID to refresh the membership rather than creating a
// new audience each run (audiences rebuild their match in Meta's backend).
//
// sourceListingId is set only for "viewed_listing_30d" rows so a single
// dealer can have many per-listing audiences without name collisions.
model MetaCustomAudience {
  id              String   @id @default(uuid())
  dealerId        String
  audienceKind    String
  sourceListingId String?
  sourceVehicleId String?
  metaAudienceId  String   // The ID Meta returned, used for PUT refresh
  metaAdAccountId String   // The ad account this audience lives under
  name            String
  description     String?
  estimatedSize   Int?     // Last-known size from Meta API (refreshed on cron run)
  lastRefreshedAt DateTime?
  lastErrorAt     DateTime?
  lastErrorMessage String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dealer Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@unique([dealerId, audienceKind, sourceListingId, sourceVehicleId])
  @@index([dealerId])
  @@index([metaAudienceId])
}
